{% extends 'base.html.twig' %}

{% block title %}Új vélemény{% endblock %}

{% block body %}
    <div class="container py-5">

        <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-7">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h1 class="fw-bold mb-1">Új vélemény</h1>
                        <p class="text-muted mb-0">
                            Oszd meg a tapasztalataidat
                        </p>
                    </div>

                    <a href="{{ path('app_review') }}" class="btn btn-outline-dark">
                        Vissza
                    </a>
                </div>

                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 p-md-5">

                        {{ form_start(form) }}

                        <div class="mb-4">
                            {{ form_label(form.companyName, 'Cégnév', {
                                label_attr: {
                                    class: 'form-label fw-semibold'
                                }
                            }) }}

                            {{ form_widget(form.companyName, {
                                attr: {
                                    class: 'form-control form-control-lg rounded-3'
                                }
                            }) }}

                            {{ form_errors(form.companyName) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.rating, 'Értékelés (1-5)', {
                                label_attr: {
                                    class: 'form-label fw-semibold'
                                }
                            }) }}

                            {{ form_widget(form.rating, {
                                attr: {
                                    class: 'form-control form-control-lg rounded-3',
                                    min: 1,
                                    max: 5
                                }
                            }) }}

                            {{ form_errors(form.rating) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.reviewText, 'Vélemény', {
                                label_attr: {
                                    class: 'form-label fw-semibold'
                                }
                            }) }}

                            {{ form_widget(form.reviewText, {
                                attr: {
                                    class: 'form-control rounded-3',
                                    rows: 6
                                }
                            }) }}

                            {{ form_errors(form.reviewText) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.authorEmail, 'Email cím', {
                                label_attr: {
                                    class: 'form-label fw-semibold'
                                }
                            }) }}

                            {{ form_widget(form.authorEmail, {
                                attr: {
                                    class: 'form-control form-control-lg rounded-3'
                                }
                            }) }}

                            {{ form_errors(form.authorEmail) }}
                        </div>

                        <button type="submit" class="btn btn-dark btn-lg rounded-3 w-100">
                            Vélemény beküldése
                        </button>

                        {{ form_end(form) }}

                    </div>
                </div>

            </div>
        </div>

    </div>
{% endblock %}

